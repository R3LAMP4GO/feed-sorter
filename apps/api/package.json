{
  "name": "@feedsorter/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --env-file=.env.local --import tsx/esm --watch src/index.ts",
    "start": "node --env-file=.env.local --import tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "set-tier": "tsx scripts/set-tier.ts",
    "dev-mint-token": "tsx scripts/dev-mint-token.ts",
    "test": "vitest run",
    "test:auth": "vitest run tests/unit/middleware.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "resend": "^4.0.0",
    "stripe": "^17.4.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0"
  }
}
